+    /// Fan-out tool call: one assistant emits multiple parallel tool calls
+    /// whose results are non-contiguous in the rope. Compaction must drop
+    /// ALL result spans together with the assistant — never leave any part
+    /// of the exchange orphaned.
+    ///
+    /// This is the core scenario the call_id-based exchange grouping fixes:
+    /// adjacency-based clustering would only catch the first consecutive run
+    /// and could leave non-contiguous results or partial exchanges behind.
+    #[test]
+    fn fanout_tool_calls_drop_as_one_exchange() {
+        // One assistant fans out two tool calls; their results are separated
+        // by a User turn (non-contiguous). Both a2/a3 are preserved.
+        let rope = RetainedRope::from_spans(vec![
+            span("sys", SpanKind::System, "system"),
+            assistant_with_tool_calls(
+                "a_fan",
+                &["call-bash", "call-read"],
+                "[tool_call:bash(...)][tool_call:read(...)]",
+            ),
+            tool_result(2, "call-bash", "bash output here"),
+            span("u_intermediate", SpanKind::User, "intermediate"),
+            tool_result(4, "call-read", "read output here"),
+            span("a2", SpanKind::Assistant, "done with both"),
+            span("a3", SpanKind::Assistant, "final answer"),
+        ]);
+        // Force tier 2 drops.
+        let target = target_from_rope(&rope, 0.5);
+        let r = SpanFamilyDropPolicy::new().compact(&rope, target);
+        let drops = dropped_ids(&r);
+        let survivors = surviving_ids(&r);
+        // Either the whole exchange drops (a_fan + both results) or none of it does.
+        let assistant_dropped = drops.contains(&"a_fan");
+        let bash_dropped = drops.iter().any(|id| id.contains("call-bash"));
+        let read_dropped = drops.iter().any(|id| id.contains("call-read"));
+        assert_eq!(
