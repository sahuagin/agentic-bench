+/// Extract call ids from an assistant span's content blocks (each
+/// `ContentBlock::ToolCall` carries a unique `id`).
+fn assistant_call_ids(span: &Span) -> Vec<&str> {
+    span.blocks()
+        .map(|blocks| {
+            blocks
+                .iter()
+                .filter_map(|b| match b {
+                    crate::context::rope::ContentBlock::ToolCall(tc) => Some(tc.id.as_str()),
+                    _ => None,
+                })
+                .collect()
+        })
+        .unwrap_or_default()
+}
+
+/// Build a mapping from call_id → span indices for every tool-related
+/// exchange in the rope.  An assistant's `ContentBlock::ToolCall` id is
+/// paired with every tool_result whose span id carries that call id
+/// (via the `-tool-result:<call_id>` suffix).  This enables correct
+/// compaction when results are non-contiguous or reordered.
+fn build_call_id_map(spans: &[Span]) -> HashMap<String, Vec<usize>> {
+    let mut map: HashMap<String, Vec<usize>> = HashMap::new();
+    for (i, span) in spans.iter().enumerate() {
+        match span.kind {
+            SpanKind::Assistant => {
+                for cid in assistant_call_ids(span) {
+                    map.entry(cid.to_owned()).or_default().push(i);
+                }
+            }
+            SpanKind::ToolResult => {
+                if let Some(cid) = extract_call_id_from_span_id(span.id()) {
+                    map.entry(cid.to_owned()).or_default().push(i);
+                }
+            }
+            _ => {}
+        }
+    }
+    map
+}
