+/// Return the tool-use call ids contained in an assistant span's
+/// structured blocks. The flat text projection intentionally omits the
+/// call id, so only `blocks` is authoritative here.
+fn assistant_tool_call_ids(span: &Span) -> Vec<&str> {
+    if span.kind != SpanKind::Assistant {
+        return Vec::new();
+    }
+    span.blocks()
+        .into_iter()
+        .flatten()
+        .filter_map(|block| match block {
+            ContentBlock::ToolCall(call) => Some(call.id.as_str()),
+            _ => None,
+        })
+        .collect()
+}
+
+fn tool_result_call_id(span: &Span) -> Option<&str> {
+    if span.kind == SpanKind::ToolResult {
+        extract_call_id_from_span_id(span.id())
+    } else {
+        None
+    }
+}
+
+/// Group every assistant tool-use span with ALL tool results for any
+/// call id it emitted. Assistant spans are indivisible, so a turn that
+/// fans out to multiple tool calls forms a single exchange containing
+/// the assistant plus every result for every call in the turn,
+/// regardless of adjacency/order in the rope.
+///
+/// Older tests/fixtures may still model tool traffic as adjacent
+/// `ToolCall`/`ToolResult` spans without structured assistant blocks;
+/// keep those legacy adjacent clusters as fallback units.
+fn tool_exchange_units(spans: &[Span]) -> Vec<Vec<usize>> {
+    let mut result_by_call_id: HashMap<&str, Vec<usize>> = HashMap::new();
+    for (idx, span) in spans.iter().enumerate() {
+        if let Some(call_id) = tool_result_call_id(span) {
+            result_by_call_id.entry(call_id).or_default().push(idx);
+        }
+    }
+
+    let mut units = Vec::new();
+    let mut structured_members = HashSet::new();
+    for (idx, span) in spans.iter().enumerate() {
+        let call_ids = assistant_tool_call_ids(span);
+        if call_ids.is_empty() {
+            continue;
+        }
+
+        let mut unit = vec![idx];
+        for call_id in call_ids {
+            if let Some(results) = result_by_call_id.get(call_id) {
+                unit.extend(results.iter().copied());
+            }
+        }
+        unit.sort_unstable();
+        unit.dedup();
+        structured_members.extend(unit.iter().copied());
+        units.push(unit);
+    }
+
+    for cluster in tool_clusters(spans) {
+        if cluster.iter().any(|idx| structured_members.contains(idx)) {
+            continue;
+        }
+        let mut unit = Vec::new();
+        if let Some(&first_idx) = cluster.first() {
+            if first_idx > 0 && spans[first_idx - 1].kind == SpanKind::Assistant {
+                unit.push(first_idx - 1);
+            }
+        }
+        unit.extend(cluster);
+        unit.sort_unstable();
+        unit.dedup();
+        units.push(unit);
+    }
+
+    units.sort_by_key(|unit| unit.iter().copied().min().unwrap_or(usize::MAX));
+    units
+}
