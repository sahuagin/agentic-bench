-            Ok(n) => enabled(n),
-            Err(_) => {
-                tracing::debug!(
-                    flag = %flag,
-                    "unrecognized --thinking value for anthropic; using medium budget"
-                );
-                enabled(10_240)
-            }
-        },
-    })
+    Some(level.to_string())
 }
 
